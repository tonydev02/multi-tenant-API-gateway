# Backend
ENVIRONMENT=development
PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_ISSUER=gateway-admin
JWT_EXPIRY_MINUTES=60
BOOTSTRAP_ON_START=true
BOOTSTRAP_TENANT_NAME=Acme
BOOTSTRAP_TENANT_SLUG=acme
BOOTSTRAP_ADMIN_EMAIL=admin@acme.local
BOOTSTRAP_ADMIN_PASSWORD=changeme123456
DATABASE_URL=postgres://gateway:gateway@127.0.0.1:55432/gateway?sslmode=disable
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
PROXY_TIMEOUT_SECONDS=10
PROXY_UPSTREAMS=1:billing=http://localhost:18081,1:catalog=http://localhost:18082,2:billing=http://localhost:28081
REDIS_ADDR=127.0.0.1:56379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# PostgreSQL
POSTGRES_DB=gateway
POSTGRES_USER=gateway
POSTGRES_PASSWORD=gateway
POSTGRES_HOST=localhost
POSTGRES_PORT=55432

# Redis
REDIS_HOST=localhost
REDIS_PORT=56379
