# Backend prod-lite environment (Render)
ENVIRONMENT=production
PORT=8080
FRONTEND_ORIGIN=https://your-prod-frontend.pages.dev

# Security
JWT_SECRET=replace-with-a-rotated-strong-secret-at-least-32-chars
JWT_ISSUER=gateway-admin
JWT_EXPIRY_MINUTES=30

# Always off in production; create tenants via admin register flow.
BOOTSTRAP_ON_START=false
BOOTSTRAP_TENANT_NAME=
BOOTSTRAP_TENANT_SLUG=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/gateway?sslmode=require
DB_MAX_OPEN_CONNS=15
DB_MAX_IDLE_CONNS=8

REDIS_ADDR=your-redis-host:6379
REDIS_PASSWORD=your-upstash-password
REDIS_DB=0
REDIS_TLS=true

RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
PROXY_TIMEOUT_SECONDS=10
PROXY_UPSTREAMS=1:billing=https://example-upstream-a.com,1:catalog=https://example-upstream-b.com
