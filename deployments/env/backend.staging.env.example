# Backend staging environment (Render)
ENVIRONMENT=staging
PORT=8080
FRONTEND_ORIGIN=https://your-staging-frontend.pages.dev

# Security
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=gateway-admin
JWT_EXPIRY_MINUTES=60

# Bootstrap should stay OFF for internet-facing deploys.
BOOTSTRAP_ON_START=false
BOOTSTRAP_TENANT_NAME=
BOOTSTRAP_TENANT_SLUG=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Neon Postgres connection string
DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/gateway?sslmode=require
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5

# Upstash Redis
REDIS_ADDR=your-redis-host:6379
REDIS_USERNAME=default
REDIS_PASSWORD=your-upstash-password
REDIS_DB=0
REDIS_TLS=true

# Gateway behavior
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
PROXY_TIMEOUT_SECONDS=10
PROXY_UPSTREAMS=1:billing=https://example-upstream-a.com,1:catalog=https://example-upstream-b.com
